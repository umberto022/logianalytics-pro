# Configuración de Base de Datos
DATABASE_URL=postgresql://usuario:password@localhost/logi_analytics
# O usar SQLite para desarrollo
# DATABASE_URL=sqlite:///./logi_analytics.db

# Configuración de API
API_KEY=sk-1234567890abcdef
RATE_LIMIT=1000
API_TIMEOUT=30

# Configuración de Email
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=notificaciones@logianalytics.com
SMTP_PASSWORD=tu_password_smtp
SMTP_FROM_EMAIL=notificaciones@logianalytics.com

# Configuración de SMS
SMS_PROVIDER=twilio
SMS_API_KEY=tu_api_key_twilio
SMS_PHONE_NUMBER=+52 55 1234 5678

# Configuración de GPS
GPS_PROVIDER=google_maps
GPS_API_KEY=tu_api_key_google_maps

# Configuración de Integraciones
ERP_ENDPOINT=https://erp.miempresa.com/api
ERP_USERNAME=erp_user
ERP_PASSWORD=erp_password

WMS_ENDPOINT=https://wms.miempresa.com/api
WMS_TOKEN=wms_token_123

# Configuración de Seguridad
SECRET_KEY=tu_secret_key_muy_segura
JWT_SECRET_KEY=tu_jwt_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Configuración de Respaldos
BACKUP_ENABLED=true
BACKUP_FREQUENCY=daily
BACKUP_RETENTION_DAYS=30
BACKUP_DESTINATION=aws_s3
BACKUP_BUCKET=logi-analytics-backups

# Configuración de Logs
LOG_LEVEL=INFO
LOG_RETENTION_DAYS=90
LOG_DETAILED_USER_ACTIONS=true

# Configuración de Monitoreo
MONITORING_ENABLED=true
METRICS_ENDPOINT=http://localhost:9090/metrics
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/tu/webhook/url

# Configuración de Desarrollo
DEBUG=true
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Configuración de Producción
# DEBUG=false
# ENVIRONMENT=production
# CORS_ORIGINS=https://app.logianalytics.com,https://admin.logianalytics.com
